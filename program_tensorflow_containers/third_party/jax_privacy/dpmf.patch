# This patch aims to include the parts of jax_privacy that are needed to
# run DPMF, excluding only the experimental module which requires pydantic.
#
# common_typos_disable
diff --git BUILD BUILD
new file mode 100644
index 0000000..f3490d5
--- /dev/null
+++ BUILD
@@ -0,0 +1,3 @@
+package(
+    default_visibility = ["//visibility:public"],
+)
\ No newline at end of file
diff --git jax_privacy/BUILD jax_privacy/BUILD
new file mode 100644
index 0000000..d67bcf3
--- /dev/null
+++ jax_privacy/BUILD
@@ -0,0 +1,20 @@
+load("@rules_python//python:defs.bzl", "py_library")
+
+package(
+    default_visibility = ["//visibility:public"],
+)
+
+py_library(
+	name = "jax_privacy",
+	srcs = glob(["**/*.py"], exclude = ["experimental/**/*.py"]),
+	deps = [
+		"@pypi//absl_py",
+		"@pypi//chex",
+		"@pypi//dp_accounting",
+		"@pypi//jax",
+		"@pypi//jaxlib",
+		"@pypi//numpy",
+		"@pypi//optax",
+		"@pypi//scipy",
+	]
+)
\ No newline at end of file
diff --git jax_privacy/__init__.py jax_privacy/__init__.py
index a8b3ad1..83148c5 100644
--- jax_privacy/__init__.py
+++ jax_privacy/__init__.py
@@ -17,7 +17,6 @@
 from jax_privacy import accounting
 from jax_privacy import auditing
 from jax_privacy import batch_selection
-from jax_privacy import experimental
 from jax_privacy import matrix_factorization
 from jax_privacy import noise_addition

