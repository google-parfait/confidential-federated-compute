# Use @python_host//:python instead of @python//:defs.bzl interpreter.

--- third_party/py/BUILD.tpl
+++ third_party/py/BUILD.tpl
@@ -5,16 +5,15 @@
 # Point both runtimes to the same python binary to ensure we always
 # use the python binary specified by ./configure.py script.
 load("@bazel_tools//tools/python:toolchain.bzl", "py_runtime_pair")
-load("@python//:defs.bzl", "interpreter")
 
 py_runtime(
     name = "py2_runtime",
-    interpreter_path = interpreter,
+    interpreter = "@python_host//:python",
     python_version = "PY2",
 )
 
 py_runtime(
     name = "py3_runtime",
-    interpreter_path = interpreter,
+    interpreter = "@python_host//:python",
     python_version = "PY3",
 )
