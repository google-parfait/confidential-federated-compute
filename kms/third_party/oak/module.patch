# Add additional crates used by CFC and its dependencies. Since crate_universe
# doesn't share crates between modules, we instead add them to Oak's module
# with a patch (https://github.com/bazelbuild/rules_rust/issues/3157).
--- MODULE.bazel
+++ MODULE.bazel
@@ -514,2 +514,42 @@
 # Crate Specifications and Annotations
 # -------------------------------------
+crate.spec(
+    package = "ahash",
+    repositories = ALL_STD,
+    version = "0.8.11",
+)
+crate.spec(
+    package = "getset",
+    repositories = ALL_STD,
+    version = "0.1.6",
+)
+crate.spec(
+    package = "integer-encoding",
+    repositories = ALL_STD,
+    version = "4.0.2",
+)
+crate.spec(
+    package = "slog",
+    repositories = ALL_STD,
+    version = "2.8.2",
+)
+crate.spec(
+    package = "slog-term",
+    repositories = ALL_STD,
+    version = "2.9.2",
+)
+crate.spec(
+    package = "spin",
+    repositories = ALL_STD,
+    version = "0.9.8",
+)
+crate.spec(
+    package = "test-log",
+    repositories = ALL_STD,
+    version = "0.2.19",
+)
+crate.spec(
+    package = "tracing-slog",
+    repositories = ALL_STD,
+    version = "0.3.0",
+)
@@ -1203,7 +1248,7 @@
 crate.spec(
     default_features = True,
-    features = [],
+    features = ["small_rng"],  # Required by raft_rs.
     package = "rand",
     repositories = ALL_STD,
-    version = "0.9.0",
+    version = "0.8.5",  # raft_rs doesn't support 0.9.
 )
@@  -1618,7 +1658,7 @@
 crate.spec(
     default_features = True,
-    features = [],
+    features = ["rt"],  # For AbortOnDropHandle.
     package = "tokio-util",
     repositories = ALL_STD,
     version = "0.7.10",
 )
